{
  "name": "language-check",
  "displayName": "Language Check",
  "version": "0.4.0",
  "description": "Multilingual prose linter powered by tree-sitter extraction and pluggable checking engines",
  "publisher": "KaiErikNiermann",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KaiErikNiermann/LangCheck"
  },
  "bugs": {
    "url": "https://github.com/KaiErikNiermann/LangCheck/issues"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.109.0"
  },
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:html",
    "onLanguage:latex",
    "onLanguage:forester",
    "onLanguage:tinylang",
    "onLanguage:rst",
    "onLanguage:sweave",
    "onLanguage:mdx",
    "onLanguage:xhtml",
    "onLanguage:bibtex",
    "onLanguage:org",
    "onLanguage:typst"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "language-check.checkDocument",
        "title": "%command.checkDocument%"
      },
      {
        "command": "language-check.openSpeedFix",
        "title": "%command.openSpeedFix%"
      },
      {
        "command": "language-check.checkWorkspace",
        "title": "%command.checkWorkspace%"
      },
      {
        "command": "language-check.selectLanguage",
        "title": "%command.selectLanguage%"
      },
      {
        "command": "language-check.openInspector",
        "title": "%command.openInspector%"
      },
      {
        "command": "language-check.switchCore",
        "title": "%command.switchCore%"
      },
      {
        "command": "language-check.toggleTrace",
        "title": "%command.toggleTrace%"
      },
      {
        "command": "language-check.showTrace",
        "title": "%command.showTrace%"
      },
      {
        "command": "language-check.manageEngines",
        "title": "%command.manageEngines%"
      },
      {
        "command": "language-check.skipLatexEnv",
        "title": "%command.skipLatexEnv%"
      },
      {
        "command": "language-check.skipLatexCommand",
        "title": "%command.skipLatexCommand%"
      },
      {
        "command": "language-check.downloadBinary",
        "title": "%command.downloadBinary%"
      },
      {
        "command": "language-check.restartLTDocker",
        "title": "%command.restartLTDocker%"
      },
      {
        "command": "language-check.restartLanguageServer",
        "title": "%command.restartLanguageServer%"
      },
      {
        "command": "language-check.toggleInlayHints",
        "title": "%command.toggleInlayHints%"
      },
      {
        "command": "language-check.managePlugins",
        "title": "%command.managePlugins%"
      }
    ],
    "keybindings": [
      {
        "command": "language-check.openSpeedFix",
        "key": "alt+f",
        "mac": "alt+f",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "languageCheck.core.channel": {
          "type": "string",
          "default": "stable",
          "enum": [
            "stable",
            "canary",
            "dev"
          ],
          "enumDescriptions": [
            "%config.core.channel.stable%",
            "%config.core.channel.canary%",
            "%config.core.channel.dev%"
          ],
          "description": "%config.core.channel%"
        },
        "languageCheck.core.binaryPath": {
          "type": "string",
          "default": "",
          "description": "%config.core.binaryPath%"
        },
        "languageCheck.trace.enable": {
          "type": "boolean",
          "default": false,
          "description": "%config.trace.enable%"
        },
        "languageCheck.check.trigger": {
          "type": "string",
          "default": "onChange",
          "enum": [
            "onChange",
            "onSave"
          ],
          "enumDescriptions": [
            "%config.check.trigger.onChange%",
            "%config.check.trigger.onSave%"
          ],
          "description": "%config.check.trigger%"
        },
        "languageCheck.performance.highPerformanceMode": {
          "type": "boolean",
          "default": false,
          "description": "%config.performance.hpm%"
        },
        "languageCheck.dictionaries.bundled": {
          "type": "boolean",
          "default": true,
          "description": "%config.dictionaries.bundled%"
        },
        "languageCheck.dictionaries.paths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%config.dictionaries.paths%"
        },
        "languageCheck.workspace.indexOnOpen": {
          "type": "boolean",
          "default": false,
          "description": "%config.workspace.indexOnOpen%"
        },
        "languageCheck.workspace.dbPath": {
          "type": "string",
          "default": "",
          "description": "%config.workspace.dbPath%"
        },
        "languageCheck.plugins": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "description": "Path to the .wasm plugin file"
              },
              "enabled": {
                "type": "boolean",
                "default": true,
                "description": "Whether the plugin is enabled"
              },
              "name": {
                "type": "string",
                "description": "Display name (defaults to filename)"
              },
              "languages": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Language IDs to restrict this plugin to"
              }
            },
            "required": [
              "path"
            ]
          },
          "default": [],
          "description": "%config.plugins%"
        }
      }
    },
    "walkthroughs": [
      {
        "id": "language-check.welcome",
        "title": "%walkthrough.title%",
        "description": "%walkthrough.description%",
        "steps": [
          {
            "id": "language-check.welcome.check",
            "title": "%walkthrough.check.title%",
            "description": "%walkthrough.check.description%",
            "media": {
              "markdown": "media/walkthrough-check.md"
            }
          },
          {
            "id": "language-check.welcome.speedfix",
            "title": "%walkthrough.speedfix.title%",
            "description": "%walkthrough.speedfix.description%",
            "media": {
              "markdown": "media/walkthrough-speedfix.md"
            }
          },
          {
            "id": "language-check.welcome.language",
            "title": "%walkthrough.language.title%",
            "description": "%walkthrough.language.description%",
            "media": {
              "markdown": "media/walkthrough-language.md"
            }
          },
          {
            "id": "language-check.welcome.configure",
            "title": "%walkthrough.configure.title%",
            "description": "%walkthrough.configure.description%",
            "media": {
              "markdown": "media/walkthrough-configure.md"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "proto:gen": "pbjs -t static-module -w commonjs -o src/proto/checker.js ../proto/checker.proto && pbts -o src/proto/checker.d.ts src/proto/checker.js",
    "build": "node esbuild.mjs --production",
    "build:dev": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest",
    "vsce:package": "pnpm run build && vsce package --no-dependencies",
    "vsce:ls": "vsce ls --no-dependencies"
  },
  "keywords": [],
  "author": "",
  "packageManager": "pnpm@10.14.0",
  "dependencies": {
    "@vscode/l10n": "^0.0.18",
    "long": "^5.3.2",
    "protobufjs": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/long": "^5.0.0",
    "@types/node": "^25.3.2",
    "@types/vscode": "^1.109.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "protobufjs-cli": "^2.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
