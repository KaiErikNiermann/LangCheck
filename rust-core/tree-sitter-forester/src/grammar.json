{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "forester",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_node"
      }
    },
    "_node": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "command"
        },
        {
          "type": "SYMBOL",
          "name": "display_math"
        },
        {
          "type": "SYMBOL",
          "name": "inline_math"
        },
        {
          "type": "SYMBOL",
          "name": "verbatim"
        },
        {
          "type": "SYMBOL",
          "name": "wiki_link"
        },
        {
          "type": "SYMBOL",
          "name": "escape"
        },
        {
          "type": "SYMBOL",
          "name": "brace_group"
        },
        {
          "type": "SYMBOL",
          "name": "bracket_group"
        },
        {
          "type": "SYMBOL",
          "name": "paren_group"
        },
        {
          "type": "SYMBOL",
          "name": "comment"
        },
        {
          "type": "SYMBOL",
          "name": "text"
        }
      ]
    },
    "command": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "command_name"
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "brace_group"
                },
                {
                  "type": "SYMBOL",
                  "name": "bracket_group"
                },
                {
                  "type": "SYMBOL",
                  "name": "paren_group"
                }
              ]
            }
          }
        ]
      }
    },
    "command_name": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "PATTERN",
            "value": "\\\\xmlns:[a-zA-Z]+"
          },
          {
            "type": "PATTERN",
            "value": "\\\\<[A-Za-z][A-Za-z0-9\\-]*(?::[A-Za-z][A-Za-z0-9\\-]*)?>"
          },
          {
            "type": "PATTERN",
            "value": "\\\\[A-Za-z0-9\\-\\/\\?\\*]+"
          }
        ]
      }
    },
    "brace_group": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_node"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "bracket_group": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_node"
          }
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "paren_group": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_node"
          }
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "display_math": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "##{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_math_node"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "inline_math": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_math_node"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "_math_node": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "math_escape"
        },
        {
          "type": "SYMBOL",
          "name": "math_command"
        },
        {
          "type": "SYMBOL",
          "name": "math_brace_group"
        },
        {
          "type": "SYMBOL",
          "name": "math_bracket_group"
        },
        {
          "type": "SYMBOL",
          "name": "math_paren_group"
        },
        {
          "type": "SYMBOL",
          "name": "math_text"
        }
      ]
    },
    "math_escape": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "PATTERN",
          "value": "\\\\[\\\\\\{\\}\\[\\]#%, \"`;_\\|&]"
        }
      }
    },
    "math_command": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "command_name"
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "math_brace_group"
                },
                {
                  "type": "SYMBOL",
                  "name": "math_bracket_group"
                },
                {
                  "type": "SYMBOL",
                  "name": "math_paren_group"
                }
              ]
            }
          }
        ]
      }
    },
    "math_brace_group": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_math_node"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "math_bracket_group": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_math_node"
          }
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "math_paren_group": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_math_node"
          }
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "math_text": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -1,
        "content": {
          "type": "PATTERN",
          "value": "[^\\\\\\{\\}\\[\\]\\(\\)\\n\\t\\r ]+"
        }
      }
    },
    "escape": {
      "type": "PATTERN",
      "value": "\\\\[\\\\\\{\\}\\[\\]#%, \"`;_\\|]"
    },
    "wiki_link": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "[["
          },
          {
            "type": "PATTERN",
            "value": "[^\\]\\n]*"
          },
          {
            "type": "STRING",
            "value": "]]"
          }
        ]
      }
    },
    "comment": {
      "type": "PATTERN",
      "value": "%[^\\n]*"
    },
    "text": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -1,
        "content": {
          "type": "PATTERN",
          "value": "[^\\\\\\{\\}\\[\\]\\(\\)\\n\\t %`]+"
        }
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t\\r\\n]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "verbatim"
    }
  ],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}